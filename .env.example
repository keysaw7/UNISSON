# ============================================================================
# UNISSON — Variables d'environnement
# Copier ce fichier en `.env` et ne renseigner QUE ce dont vous avez besoin :
# toutes les variables ci-dessous sont optionnelles et ont un repli sûr
# (adapters en mémoire / StubLlmAdapter déterministe). Rien n'est requis pour
# lancer `npm test` ou `npm run start:api` en local.
# ============================================================================

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------
# Port HTTP de l'API NestJS.
PORT=3000

# ----------------------------------------------------------------------------
# Persistance PostgreSQL (optionnelle)
# ----------------------------------------------------------------------------
# Sans DATABASE_URL : adapters en mémoire (dev/CI), aucune base requise.
# Avec DATABASE_URL : adapters Postgres/Drizzle derrière les mêmes ports.
#   npm run db:up      # docker compose : Postgres 16 (identifiants ci-dessous)
#   npm run db:setup   # migre le schéma + charge le graphe Japonais N5
DATABASE_URL=postgres://unisson:unisson@localhost:5432/unisson

# ----------------------------------------------------------------------------
# AI Gateway — fournisseur LLM (optionnel)
# ----------------------------------------------------------------------------
# Sans clé API : StubLlmAdapter (déterministe, aucun appel réseau, dev/CI).
# Avec ANTHROPIC_API_KEY et/ou OPENAI_API_KEY : l'AI Gateway (cache, boucle de
# réparation, fallback, télémétrie — voir ARCHITECTURE.md §10) route vers le(s)
# vrai(s) fournisseur(s) derrière EXACTEMENT le même `LLMPort`.
#
# - Une seule clé renseignée  → ce fournisseur est primaire, le stub sert de
#   secours automatique si l'appel échoue.
# - Les deux clés renseignées → Anthropic est primaire par défaut, OpenAI sert
#   de secours (utiliser LLM_PROVIDER pour inverser cette préférence).
# - Aucune clé renseignée     → LLM_PROVIDER est ignoré, sauf s'il vaut "stub".

# Force explicitement le fournisseur à utiliser : "anthropic" | "openai" | "stub".
# Laisser vide pour la détection automatique décrite ci-dessus.
# Utile pour forcer "stub" en CI même si des clés sont présentes dans l'environnement,
# ou pour figer un choix en production plutôt que de dépendre de l'ordre des clés.
LLM_PROVIDER=

# --- Anthropic (Claude) ------------------------------------------------------
# Clé API : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Modèle utilisé pour les capacités `parse_goal` et `generate_content`.
# Défaut applicatif si vide : claude-3-5-haiku-20241022 (rapide et peu coûteux).
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- OpenAI -------------------------------------------------------------------
# Clé API : https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Modèle utilisé (doit supporter response_format: json_object).
# Défaut applicatif si vide : gpt-4o-mini (rapide et peu coûteux, PAS un modèle de raisonnement).
# Exemple avec un modèle de raisonnement (voir bloc dédié ci-dessous) : gpt-5-nano
OPENAI_MODEL=gpt-4o-mini
# Optionnel : identifiant d'organisation OpenAI (comptes multi-organisations uniquement).
OPENAI_ORGANIZATION=

# --- OpenAI : modèles de RAISONNEMENT uniquement (gpt-5*, o1, o3, o4…) --------
# L'adapter détecte automatiquement un modèle de raisonnement d'après son préfixe
# (OPENAI_MODEL commençant par "gpt-5", "o1", "o3" ou "o4") et applique alors des
# défauts adaptés SANS rien à configurer : reasoning_effort=minimal, verbosity=low,
# max_completion_tokens=2048. Ces trois variables permettent de les surcharger —
# laisser vide pour garder les défauts (recommandés pour gpt-5-nano avec nos
# capacités d'extraction JSON déterministe : pas besoin de délibération).
# Elles sont ignorées (non envoyées à l'API) pour un modèle non-raisonnement.
#
# reasoning_effort : none | minimal | low | medium | high | xhigh
#   -> minimal/low pour de l'extraction/formatage rapide (notre cas) ;
#      medium/high seulement si la tâche exige une vraie délibération.
OPENAI_REASONING_EFFORT=minimal
# verbosity : low | medium | high (longueur/style de la sortie).
OPENAI_VERBOSITY=low
# Plafond de tokens GÉNÉRÉS, raisonnement interne compris (facturé même s'il n'apparaît
# pas dans la réponse). Trop bas -> le modèle peut épuiser son budget en raisonnement
# et renvoyer une sortie vide (l'adapter lève alors une erreur explicite le signalant).
OPENAI_MAX_COMPLETION_TOKENS=2048

# ----------------------------------------------------------------------------
# Frontend (apps/web) — pattern BFF (voir le plan frontend UNISSON)
# ----------------------------------------------------------------------------
# URL de l'API NestJS appelée CÔTÉ SERVEUR par apps/web (jamais depuis le navigateur : aucun CORS
# requis). Par défaut, l'API locale démarrée avec `npm run start:api`.
UNISSON_API_URL=http://localhost:3000

# Secret HMAC signant le cookie d'identité invité (learnerId pseudonyme, V1 sans IAM réelle —
# §13.2 ARCHITECTURE.md). Ne protège aucune donnée sensible ; détecte seulement un cookie altéré.
# À renseigner en production ; un défaut de dev est utilisé sinon.
LEARNER_SESSION_SECRET=

# ----------------------------------------------------------------------------
# Observabilité (optionnel)
# ----------------------------------------------------------------------------
# Si défini, les erreurs AI Gateway sont aussi émises en JSON structuré (hook Sentry-ready).
SENTRY_DSN=
